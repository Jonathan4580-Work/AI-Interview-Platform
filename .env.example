NODE_ENV=development
APP_ENV=development
APP_NAME=Aptly
APP_URL=http://localhost:3000
CANDIDATE_APP_URL=http://localhost:3000
INTERNAL_APP_URL=http://localhost:3000
LOG_LEVEL=info

DATABASE_URL=mysql://root:@127.0.0.1:3306/aptly_local
DIRECT_DATABASE_URL=mysql://root:@127.0.0.1:3306/aptly_local
REDIS_URL=redis://localhost:6379
SESSION_SECRET_REF=local/dev/session
CSRF_SECRET_REF=local/dev/csrf
TOKEN_PEPPER_SECRET_REF=local/dev/token-pepper
ENCRYPTION_KEY_SECRET_REF=local/dev/encryption

REQUEST_ID_HEADER=x-request-id
CORRELATION_ID_HEADER=x-correlation-id
EMAIL_DELIVERY_MODE=preview
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM_EMAIL=no-reply@aptly.local
SMTP_FROM_NAME=Aptly
SMTP_REPLY_TO_EMAIL=support@aptly.local
SMTP_SECRET_REF=local/dev/smtp
OBJECT_STORAGE_SECRET_REF=local/dev/object-storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./storage
OBJECT_STORAGE_PROVIDER=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=aptly-media-dev
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_ACCESS_KEY_ID=aptlyminio
OBJECT_STORAGE_SECRET_ACCESS_KEY=aptlyminiosecret
OBJECT_STORAGE_CORS_ALLOWED_ORIGINS=http://localhost:3000
WORKER_ORCHESTRATION_CONCURRENCY=5
WORKER_MEDIA_CONCURRENCY=3
WORKER_PROVIDER_BOUND_CONCURRENCY=2
WORKER_NOTIFICATIONS_CONCURRENCY=5
WORKER_TRANSCRIPTION_CONCURRENCY=2
WORKER_EVALUATION_CONCURRENCY=2
WORKER_REPORTING_CONCURRENCY=3
WORKER_EXPORTS_CONCURRENCY=2
WORKER_RETENTION_CONCURRENCY=2
WORKER_INTEGRATIONS_CONCURRENCY=2
WORKER_WEBHOOKS_CONCURRENCY=5
WORKER_TENANT_FAIRNESS_LIMIT=10
TRANSCRIPTION_PROVIDER=development
EVALUATION_PROVIDER=deterministic
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
EVALUATION_PROVIDER_TIMEOUT_MS=30000
APTLY_MONITORING_ENABLED=true
DATA_REGION_DEFAULT=US

BOOTSTRAP_PLATFORM_ADMIN_EMAIL=
BOOTSTRAP_PLATFORM_ADMIN_NAME=
BOOTSTRAP_PLATFORM_ADMIN_PASSWORD=
BOOTSTRAP_COMPANY_NAME=
BOOTSTRAP_COMPANY_SLUG=
BOOTSTRAP_COMPANY_ADMIN_EMAIL=
BOOTSTRAP_COMPANY_ADMIN_NAME=
BOOTSTRAP_COMPANY_ADMIN_PASSWORD=
