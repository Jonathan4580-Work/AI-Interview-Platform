NODE_ENV=development
APP_NAME=Aptly
APP_URL=http://localhost:3000
LOG_LEVEL=info

DATABASE_URL=postgresql://aptly:aptly@localhost:5432/aptly?schema=public
DIRECT_DATABASE_URL=postgresql://aptly:aptly@localhost:5432/aptly?schema=public
REDIS_URL=redis://localhost:6379

REQUEST_ID_HEADER=x-request-id
CORRELATION_ID_HEADER=x-correlation-id
EMAIL_DELIVERY_MODE=preview
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM_EMAIL=no-reply@aptly.local
SMTP_FROM_NAME=Aptly
SMTP_REPLY_TO_EMAIL=support@aptly.local
SMTP_SECRET_REF=local/dev/smtp
OBJECT_STORAGE_SECRET_REF=local/dev/object-storage
OBJECT_STORAGE_PROVIDER=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=aptly-media-dev
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_ACCESS_KEY_ID=aptlyminio
OBJECT_STORAGE_SECRET_ACCESS_KEY=aptlyminiosecret
WORKER_ORCHESTRATION_CONCURRENCY=5
WORKER_MEDIA_CONCURRENCY=3
WORKER_PROVIDER_BOUND_CONCURRENCY=2
WORKER_NOTIFICATIONS_CONCURRENCY=5
WORKER_TRANSCRIPTION_CONCURRENCY=2
WORKER_EVALUATION_CONCURRENCY=2
WORKER_REPORTING_CONCURRENCY=3
WORKER_EXPORTS_CONCURRENCY=2
WORKER_RETENTION_CONCURRENCY=2
WORKER_INTEGRATIONS_CONCURRENCY=2
WORKER_WEBHOOKS_CONCURRENCY=5
WORKER_TENANT_FAIRNESS_LIMIT=10
