APP_ENV=development
NODE_ENV=development
APP_NAME=Aptly
APP_URL=http://localhost:3000
CANDIDATE_APP_URL=http://localhost:3000
INTERNAL_APP_URL=http://localhost:3000
APP_TIMEZONE=Asia/Colombo

DATABASE_URL=mysql://root:@127.0.0.1:3306/aptly_local
DIRECT_DATABASE_URL=mysql://root:@127.0.0.1:3306/aptly_local

SESSION_SECRET_REF=local/session
CSRF_SECRET_REF=local/csrf
TOKEN_PEPPER_SECRET_REF=local/token-pepper
ENCRYPTION_KEY_SECRET_REF=local/encryption

EMAIL_DELIVERY_MODE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Aptly
SMTP_REPLY_TO_EMAIL=
SMTP_SECRET_REF=local/smtp

STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./storage
OBJECT_STORAGE_SECRET_REF=local/object-storage
OBJECT_STORAGE_PROVIDER=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=local
OBJECT_STORAGE_BUCKET=aptly-local
OBJECT_STORAGE_FORCE_PATH_STYLE=true

EVALUATION_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_API_URL=https://api.openai.com/v1
EVALUATION_PROVIDER_TIMEOUT_MS=30000

TRANSCRIPTION_PROVIDER=development
LOCAL_WORKER_POLL_MS=1000
LOCAL_WORKER_STALE_AFTER_MS=60000
