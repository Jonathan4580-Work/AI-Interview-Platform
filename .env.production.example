NODE_ENV=production
APP_ENV=production
APP_NAME=Aptly
APP_URL=https://app.example.com
CANDIDATE_APP_URL=https://interview.example.com
INTERNAL_APP_URL=https://app.example.com
LOG_LEVEL=info

DATABASE_URL=postgresql://<runtime-user>:<managed-secret>@<postgres-host>:5432/<database>?schema=public&sslmode=require
DIRECT_DATABASE_URL=postgresql://<migration-user>:<managed-secret>@<postgres-host>:5432/<database>?schema=public&sslmode=require
REDIS_URL=rediss://:<managed-secret>@<redis-host>:6379

SESSION_SECRET_REF=secret://production/aptly/session
CSRF_SECRET_REF=secret://production/aptly/csrf
TOKEN_PEPPER_SECRET_REF=secret://production/aptly/token-pepper
ENCRYPTION_KEY_SECRET_REF=secret://production/aptly/encryption

REQUEST_ID_HEADER=x-request-id
CORRELATION_ID_HEADER=x-correlation-id

EMAIL_DELIVERY_MODE=preview
SMTP_HOST=<smtp-host>
SMTP_PORT=587
SMTP_SECURE=true
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Aptly
SMTP_REPLY_TO_EMAIL=support@example.com
SMTP_SECRET_REF=secret://production/aptly/smtp

OBJECT_STORAGE_SECRET_REF=secret://production/aptly/object-storage
OBJECT_STORAGE_PROVIDER=s3
OBJECT_STORAGE_ENDPOINT=https://s3.example.com
OBJECT_STORAGE_PUBLIC_ENDPOINT=https://s3.example.com
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=<private-media-bucket>
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_CORS_ALLOWED_ORIGINS=https://app.example.com,https://interview.example.com

WORKER_ORCHESTRATION_CONCURRENCY=5
WORKER_MEDIA_CONCURRENCY=3
WORKER_PROVIDER_BOUND_CONCURRENCY=2
WORKER_NOTIFICATIONS_CONCURRENCY=5
WORKER_TRANSCRIPTION_CONCURRENCY=2
WORKER_EVALUATION_CONCURRENCY=2
WORKER_REPORTING_CONCURRENCY=3
WORKER_EXPORTS_CONCURRENCY=2
WORKER_RETENTION_CONCURRENCY=2
WORKER_INTEGRATIONS_CONCURRENCY=2
WORKER_WEBHOOKS_CONCURRENCY=5
WORKER_TENANT_FAIRNESS_LIMIT=10

TRANSCRIPTION_PROVIDER=development
EVALUATION_PROVIDER=openai
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=<server-only-openai-api-key-from-secret-manager>
OPENAI_MODEL=gpt-5-mini
EVALUATION_PROVIDER_TIMEOUT_MS=30000

APTLY_MONITORING_ENABLED=true
WEBHOOK_SIGNING_SECRET_REF=secret://production/aptly/webhooks
SCIM_TOKEN_SECRET_REF=secret://production/aptly/scim
SSO_GOOGLE_CLIENT_SECRET_REF=secret://production/aptly/sso/google
SSO_MICROSOFT_CLIENT_SECRET_REF=secret://production/aptly/sso/microsoft
ATS_SECRET_REF=secret://production/aptly/ats
DATA_REGION_DEFAULT=US
BACKUP_STORAGE_SECRET_REF=secret://production/aptly/backups
OBSERVABILITY_EXPORTER_ENDPOINT=https://observability.example.com/ingest
RELEASE_COMMIT_SHA=<git-commit-sha>
RELEASE_IMAGE_VERSION=<image-tag>
