{
  "name": "aptly-recruiting-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Foundation scaffold for Aptly, an enterprise browser-based interview platform.",
  "type": "module",
  "scripts": {
    "build": "npm run typecheck && npm run prisma:validate",
    "next:build": "dotenv -e .env.test -- next build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:validate": "dotenv -e .env.test -- prisma validate",
    "migrate:deploy": "prisma migrate deploy",
    "db:local:migrate": "dotenv -e .env.local -- prisma migrate deploy",
    "db:local:reset": "dotenv -e .env.local -- prisma migrate reset",
    "db:local:seed": "dotenv -e .env.local -- tsx scripts/local-seed.ts",
    "worker:local": "dotenv -e .env.local -- tsx src/workers/local.ts",
    "local:generate-secrets": "tsx scripts/local-generate-secrets.ts",
    "local:storage-smoke": "dotenv -e .env.local -- tsx scripts/local-storage-smoke.ts",
    "local:smtp-smoke": "dotenv -e .env.local -- tsx scripts/local-smtp-smoke.ts",
    "local:openai-smoke": "dotenv -e .env.local -- tsx scripts/local-openai-smoke.ts",
    "local:full-flow-status": "dotenv -e .env.local -- tsx scripts/local-full-flow-status.ts",
    "local:repair-workflow-attempts": "dotenv -e .env.local -- tsx scripts/local-repair-workflow-attempts.ts",
    "bootstrap:staging": "tsx scripts/bootstrap-staging.ts",
    "staging:reset-admin-passwords": "tsx scripts/staging-reset-admin-passwords.ts",
    "staging:reset-company-user-password": "tsx scripts/staging-reset-company-user-password.ts",
    "staging:demo": "tsx scripts/staging-demo-mvp.ts",
    "staging:mvp-smoke": "tsx scripts/staging-mvp-smoke.ts",
    "staging:object-storage-smoke": "tsx scripts/object-storage-smoke.ts",
    "staging:smtp-smoke": "tsx scripts/staging-smtp-smoke.ts",
    "staging:openai-smoke": "tsx scripts/staging-openai-smoke.ts",
    "staging:full-flow-status": "tsx scripts/staging-full-flow-status.ts",
    "dev": "next dev",
    "start": "next start",
    "worker:dev": "tsx src/workers/index.ts",
    "worker:prod": "tsx src/workers/index.ts",
    "validate:production-env": "tsx scripts/validate-production-env.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@aws-sdk/s3-request-presigner": "^3.1076.0",
    "@prisma/client": "^6.1.0",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "bullmq": "^5.34.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.2",
    "lucide-react": "^1.22.0",
    "next": "^15.1.3",
    "nodemailer": "^9.0.3",
    "openai": "^6.45.0",
    "pino": "^9.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "postcss": "^8.5.16"
  }
}
