{
  "name": "aptly-recruiting-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Foundation scaffold for Aptly, an enterprise browser-based interview platform.",
  "type": "module",
  "scripts": {
    "build": "npm run typecheck && npm run prisma:validate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:validate": "dotenv -e .env.test -- prisma validate",
    "dev": "next dev",
    "worker:dev": "tsx src/workers/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bullmq": "^5.34.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.2",
    "next": "^15.1.3",
    "pino": "^9.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "postcss": "^8.5.16"
  }
}
