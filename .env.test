NODE_ENV=test
APP_ENV=test
APP_NAME=Aptly Test
APP_URL=http://localhost:3000
LOG_LEVEL=silent

DATABASE_URL=mysql://root:@127.0.0.1:3306/aptly_test
DIRECT_DATABASE_URL=mysql://root:@127.0.0.1:3306/aptly_test
REDIS_URL=redis://localhost:6379/1

REQUEST_ID_HEADER=x-request-id
CORRELATION_ID_HEADER=x-correlation-id
EMAIL_DELIVERY_MODE=preview
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM_EMAIL=no-reply@aptly.test
SMTP_FROM_NAME=Aptly Test
SMTP_REPLY_TO_EMAIL=support@aptly.test
SMTP_SECRET_REF=test/smtp
OBJECT_STORAGE_SECRET_REF=test/object-storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./storage-test
OBJECT_STORAGE_PROVIDER=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=aptly-media-test
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_ACCESS_KEY_ID=test-minio
OBJECT_STORAGE_SECRET_ACCESS_KEY=test-minio-secret
WORKER_ORCHESTRATION_CONCURRENCY=1
WORKER_MEDIA_CONCURRENCY=1
WORKER_PROVIDER_BOUND_CONCURRENCY=1
WORKER_NOTIFICATIONS_CONCURRENCY=1
