generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  TRIALING
  ARCHIVED

  @@map("company_status")
}

enum PlatformUserStatus {
  ACTIVE
  DISABLED

  @@map("platform_user_status")
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED

  @@map("user_status")
}

enum AuditActorType {
  PLATFORM_USER
  USER
  CANDIDATE_SESSION
  SYSTEM

  @@map("audit_actor_type")
}

enum AuditRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("audit_risk_level")
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED

  @@map("idempotency_status")
}

enum SupportAccessStatus {
  REQUESTED
  ACTIVE
  EXPIRED
  REVOKED
  DENIED

  @@map("support_access_status")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED

  @@map("subscription_status")
}

enum LegalHoldStatus {
  ACTIVE
  RELEASED

  @@map("legal_hold_status")
}

enum PrivacyRequestType {
  ACCESS
  DELETION
  ANONYMIZATION
  EXPORT
  CORRECTION

  @@map("privacy_request_type")
}

enum PrivacyRequestStatus {
  RECEIVED
  VERIFYING
  PROCESSING
  COMPLETED
  DENIED

  @@map("privacy_request_status")
}

enum ExportRequestType {
  CANDIDATE_REPORT
  ROLE_SUMMARY
  AUDIT_EXPORT
  TENANT_EXPORT
  COMPLIANCE_EXPORT

  @@map("export_request_type")
}

enum ExportRequestStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  EXPIRED

  @@map("export_request_status")
}

enum DepartmentStatus {
  ACTIVE
  ARCHIVED

  @@map("department_status")
}

enum TeamStatus {
  ACTIVE
  ARCHIVED

  @@map("team_status")
}

enum TeamMemberRole {
  LEAD
  MEMBER

  @@map("team_member_role")
}

enum LocationStatus {
  ACTIVE
  ARCHIVED

  @@map("location_status")
}

enum LocationMode {
  ONSITE
  HYBRID
  REMOTE

  @@map("location_mode")
}

enum HiringPipelineStatus {
  ACTIVE
  ARCHIVED

  @@map("hiring_pipeline_status")
}

enum PipelineStageStatus {
  ACTIVE
  ARCHIVED

  @@map("pipeline_stage_status")
}

enum PipelineStageCategory {
  APPLICATION_REVIEW
  SCREEN
  INTERVIEW
  OFFER
  HIRED
  REJECTED

  @@map("pipeline_stage_category")
}

enum JobStatus {
  DRAFT
  OPEN
  PAUSED
  CLOSED
  ARCHIVED

  @@map("job_status")
}

enum JobTemplateStatus {
  ACTIVE
  ARCHIVED

  @@map("job_template_status")
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP

  @@map("employment_type")
}

enum WorkplaceType {
  ONSITE
  HYBRID
  REMOTE

  @@map("workplace_type")
}

enum SeniorityLevel {
  ENTRY
  MID
  SENIOR
  STAFF
  EXECUTIVE

  @@map("seniority_level")
}

enum InterviewPlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED

  @@map("interview_plan_status")
}

enum InterviewPlanVersionStatus {
  DRAFT
  PUBLISHED
  RETIRED

  @@map("interview_plan_version_status")
}

enum CandidateStatus {
  ACTIVE
  ARCHIVED
  MERGED

  @@map("candidate_status")
}

enum CandidateSourceType {
  MANUAL
  REFERRAL
  IMPORT
  APPLICATION
  INVITATION

  @@map("candidate_source_type")
}

enum ApplicationStatus {
  NEW
  IN_REVIEW
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
  ARCHIVED

  @@map("application_status")
}

enum CandidateDocumentType {
  RESUME
  COVER_LETTER
  PORTFOLIO
  OTHER

  @@map("candidate_document_type")
}

enum CandidateDocumentStatus {
  ACTIVE
  DELETED

  @@map("candidate_document_status")
}

enum CandidateTagStatus {
  ACTIVE
  ARCHIVED

  @@map("candidate_tag_status")
}

enum CandidateNoteVisibility {
  INTERNAL
  PRIVATE

  @@map("candidate_note_visibility")
}

enum CandidateNoteStatus {
  ACTIVE
  DELETED

  @@map("candidate_note_status")
}

enum InvitationStatus {
  DRAFT
  QUEUED
  SENT
  OPENED
  ACCEPTED
  EXPIRED
  CANCELLED

  @@map("invitation_status")
}

enum InterviewSessionStatus {
  NOT_STARTED
  READY_CHECK
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED

  @@map("interview_session_status")
}

enum ScheduleEventType {
  INTERVIEW
  DEADLINE
  REMINDER

  @@map("schedule_event_type")
}

enum ScheduleEventStatus {
  SCHEDULED
  CANCELLED
  COMPLETED

  @@map("schedule_event_status")
}

enum CalendarProvider {
  INTERNAL
  GOOGLE
  MICROSOFT

  @@map("calendar_provider")
}

enum ScheduleParticipantType {
  CANDIDATE
  USER
  EXTERNAL

  @@map("schedule_participant_type")
}

enum ScheduleResponseStatus {
  NEEDS_ACTION
  ACCEPTED
  DECLINED
  TENTATIVE

  @@map("schedule_response_status")
}

enum NotificationIntentType {
  INVITATION_CREATED
  INVITATION_REMINDER
  SCHEDULE_CREATED
  SCHEDULE_UPDATED

  @@map("notification_intent_type")
}

enum NotificationChannel {
  EMAIL

  @@map("notification_channel")
}

enum NotificationIntentStatus {
  PENDING
  CANCELLED
  DISPATCHED
  FAILED

  @@map("notification_intent_status")
}

model Company {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  status        CompanyStatus @default(TRIALING)
  primaryDomain String?       @map("primary_domain")
  logoUrl       String?       @map("logo_url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  users                   User[]
  roles                   Role[]
  auditEvents             AuditEvent[]
  idempotencyKeys         IdempotencyKey[]
  settings                CompanySettings?
  subscription            Subscription?
  entitlements            Entitlement[]
  usageCounters           UsageCounter[]
  supportAccess           SupportAccessSession[]
  legalHolds              LegalHold[]
  privacyRequests         PrivacyRequest[]
  exportRequests          ExportRequest[]
  departments             Department[]
  teams                   Team[]
  teamMembers             TeamMember[]
  locations               Location[]
  hiringPipelines         HiringPipeline[]
  pipelineStages          PipelineStage[]
  jobs                    Job[]
  jobTemplates            JobTemplate[]
  interviewPlans          InterviewPlan[]
  interviewPlanVersions   InterviewPlanVersion[]
  candidates              Candidate[]
  candidateApplications   CandidateApplication[]
  candidateDocuments      CandidateDocument[]
  candidateTags           CandidateTag[]
  candidateTagAssignments CandidateTagAssignment[]
  candidateNotes          CandidateNote[]
  candidateMergeEvents    CandidateMergeEvent[]
  candidateInvitations    CandidateInvitation[]
  interviewSessions       InterviewSession[]
  scheduleEvents          ScheduleEvent[]
  scheduleParticipants    ScheduleParticipant[]
  notificationIntents     NotificationIntent[]

  @@index([status])
  @@map("companies")
}

model PlatformUser {
  id        String             @id @default(cuid())
  email     String             @unique
  name      String
  status    PlatformUserStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  supportAccessSessions         SupportAccessSession[] @relation("SupportAccessPlatformUser")
  approvedSupportAccessSessions SupportAccessSession[] @relation("SupportAccessApprover")

  @@index([status])
  @@map("platform_users")
}

model User {
  id          String     @id @default(cuid())
  companyId   String     @map("company_id")
  email       String
  name        String
  status      UserStatus @default(INVITED)
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  company              Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  roles                UserRole[]
  legalHoldsCreated    LegalHold[]           @relation("LegalHoldCreator")
  legalHoldsReleased   LegalHold[]           @relation("LegalHoldReleaser")
  exportRequests       ExportRequest[]
  teamMemberships      TeamMember[]
  candidateNotes       CandidateNote[]
  candidateMergeEvents CandidateMergeEvent[]

  @@unique([companyId, id])
  @@unique([companyId, email])
  @@index([companyId, status])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String
  key         String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([companyId, id])
  @@unique([companyId, key])
  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String @map("user_id")
  roleId    String @map("role_id")
  companyId String @map("company_id")

  user User @relation(fields: [companyId, userId], references: [companyId, id], onDelete: Cascade)
  role Role @relation(fields: [companyId, roleId], references: [companyId, id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([companyId])
  @@map("user_roles")
}

model AuditEvent {
  id                     String         @id @default(cuid())
  companyId              String?        @map("company_id")
  actorType              AuditActorType @map("actor_type")
  actorId                String?        @map("actor_id")
  requestId              String?        @map("request_id")
  correlationId          String?        @map("correlation_id")
  sessionId              String?        @map("session_id")
  supportAccessSessionId String?        @map("support_access_session_id")
  action                 String
  resourceType           String         @map("resource_type")
  resourceId             String?        @map("resource_id")
  reason                 String?
  riskLevel              AuditRiskLevel @default(LOW) @map("risk_level")
  beforeJson             Json?          @map("before_json")
  afterJson              Json?          @map("after_json")
  ipAddress              String?        @map("ip_address")
  userAgent              String?        @map("user_agent")
  metadataJson           Json?          @map("metadata_json")
  createdAt              DateTime       @default(now()) @map("created_at")

  company              Company?              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  supportAccessSession SupportAccessSession? @relation(fields: [supportAccessSessionId], references: [id], onDelete: Restrict)

  @@index([companyId, createdAt])
  @@index([actorType, actorId])
  @@index([resourceType, resourceId])
  @@index([requestId])
  @@index([correlationId])
  @@index([supportAccessSessionId])
  @@map("audit_events")
}

model IdempotencyKey {
  id           String            @id @default(cuid())
  companyId    String?           @map("company_id")
  key          String
  scope        String
  requestHash  String            @map("request_hash")
  responseHash String?           @map("response_hash")
  status       IdempotencyStatus @default(PROCESSING)
  expiresAt    DateTime          @map("expires_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([scope, key])
  @@index([companyId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model CompanySettings {
  id                  String   @id @default(cuid())
  companyId           String   @unique @map("company_id")
  brandingJson        Json     @map("branding_json")
  retentionPolicyJson Json     @map("retention_policy_json")
  emailSettingsJson   Json     @map("email_settings_json")
  featureFlagsJson    Json     @map("feature_flags_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@map("company_settings")
}

model Subscription {
  id                     String             @id @default(cuid())
  companyId              String             @unique @map("company_id")
  status                 SubscriptionStatus @default(TRIALING)
  planKey                String             @map("plan_key")
  billingProvider        String?            @map("billing_provider")
  billingCustomerRef     String?            @map("billing_customer_ref")
  billingSubscriptionRef String?            @map("billing_subscription_ref")
  currentPeriodStart     DateTime?          @map("current_period_start")
  currentPeriodEnd       DateTime?          @map("current_period_end")
  usageJson              Json               @map("usage_json")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([status])
  @@map("subscriptions")
}

model Entitlement {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  planKey        String   @map("plan_key")
  featureKey     String   @map("feature_key")
  limitValue     Int?     @map("limit_value")
  enabled        Boolean  @default(false)
  overrideReason String?  @map("override_reason")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@unique([companyId, featureKey])
  @@index([companyId, planKey])
  @@map("entitlements")
}

model UsageCounter {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  periodStart  DateTime @map("period_start")
  periodEnd    DateTime @map("period_end")
  metricKey    String   @map("metric_key")
  count        Int      @default(0)
  metadataJson Json     @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@unique([companyId, periodStart, periodEnd, metricKey])
  @@index([companyId, metricKey])
  @@map("usage_counters")
}

model SupportAccessSession {
  id                       String              @id @default(cuid())
  companyId                String              @map("company_id")
  platformUserId           String              @map("platform_user_id")
  status                   SupportAccessStatus @default(REQUESTED)
  reasonCode               String              @map("reason_code")
  reasonText               String              @map("reason_text")
  approvedByPlatformUserId String?             @map("approved_by_platform_user_id")
  startedAt                DateTime?           @map("started_at")
  expiresAt                DateTime            @map("expires_at")
  endedAt                  DateTime?           @map("ended_at")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  company                Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  platformUser           PlatformUser  @relation("SupportAccessPlatformUser", fields: [platformUserId], references: [id], onDelete: Restrict)
  approvedByPlatformUser PlatformUser? @relation("SupportAccessApprover", fields: [approvedByPlatformUserId], references: [id], onDelete: Restrict)
  auditEvents            AuditEvent[]

  @@unique([companyId, id])
  @@index([companyId, status])
  @@index([platformUserId, status])
  @@index([expiresAt])
  @@map("support_access_sessions")
}

model LegalHold {
  id               String          @id @default(cuid())
  companyId        String          @map("company_id")
  name             String
  description      String?
  status           LegalHoldStatus @default(ACTIVE)
  createdByUserId  String          @map("created_by_user_id")
  releasedByUserId String?         @map("released_by_user_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  releasedAt       DateTime?       @map("released_at")

  company        Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdByUser  User    @relation("LegalHoldCreator", fields: [companyId, createdByUserId], references: [companyId, id], onDelete: Restrict)
  releasedByUser User?   @relation("LegalHoldReleaser", fields: [companyId, releasedByUserId], references: [companyId, id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, status])
  @@map("legal_holds")
}

model PrivacyRequest {
  id             String               @id @default(cuid())
  companyId      String               @map("company_id")
  candidateId    String?              @map("candidate_id")
  type           PrivacyRequestType
  status         PrivacyRequestStatus @default(RECEIVED)
  requesterEmail String               @map("requester_email")
  reason         String?
  completedAt    DateTime?            @map("completed_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  candidate Candidate? @relation(fields: [companyId, candidateId], references: [companyId, id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, candidateId])
  @@index([companyId, status])
  @@map("privacy_requests")
}

model ExportRequest {
  id                String              @id @default(cuid())
  companyId         String              @map("company_id")
  requestedByUserId String              @map("requested_by_user_id")
  type              ExportRequestType
  status            ExportRequestStatus @default(PENDING)
  resourceType      String?             @map("resource_type")
  resourceId        String?             @map("resource_id")
  storageKey        String?             @map("storage_key")
  expiresAt         DateTime?           @map("expires_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  company         Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  requestedByUser User    @relation(fields: [companyId, requestedByUserId], references: [companyId, id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, status])
  @@index([companyId, requestedByUserId])
  @@map("export_requests")
}

model Department {
  id          String           @id @default(cuid())
  companyId   String           @map("company_id")
  name        String
  slug        String
  description String?
  status      DepartmentStatus @default(ACTIVE)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  teams   Team[]
  jobs    Job[]

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, status])
  @@map("departments")
}

model Team {
  id           String     @id @default(cuid())
  companyId    String     @map("company_id")
  departmentId String?    @map("department_id")
  name         String
  slug         String
  description  String?
  status       TeamStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  department Department?  @relation(fields: [companyId, departmentId], references: [companyId, id], onDelete: Restrict)
  members    TeamMember[]
  jobs       Job[]

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, departmentId])
  @@index([companyId, status])
  @@map("teams")
}

model TeamMember {
  id        String         @id @default(cuid())
  companyId String         @map("company_id")
  teamId    String         @map("team_id")
  userId    String         @map("user_id")
  role      TeamMemberRole @default(MEMBER)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  team    Team    @relation(fields: [companyId, teamId], references: [companyId, id], onDelete: Cascade)
  user    User    @relation(fields: [companyId, userId], references: [companyId, id], onDelete: Cascade)

  @@unique([companyId, id])
  @@unique([companyId, teamId, userId])
  @@index([companyId, userId])
  @@map("team_members")
}

model Location {
  id          String         @id @default(cuid())
  companyId   String         @map("company_id")
  name        String
  slug        String
  mode        LocationMode
  status      LocationStatus @default(ACTIVE)
  addressJson Json?          @map("address_json")
  timeZone    String?        @map("time_zone")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  jobs    Job[]

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, status])
  @@index([companyId, mode])
  @@map("locations")
}

model HiringPipeline {
  id          String               @id @default(cuid())
  companyId   String               @map("company_id")
  name        String
  slug        String
  description String?
  status      HiringPipelineStatus @default(ACTIVE)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  deletedAt   DateTime?            @map("deleted_at")

  company      Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  stages       PipelineStage[]
  jobs         Job[]
  jobTemplates JobTemplate[]

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, status])
  @@map("hiring_pipelines")
}

model PipelineStage {
  id         String                @id @default(cuid())
  companyId  String                @map("company_id")
  pipelineId String                @map("pipeline_id")
  name       String
  slug       String
  category   PipelineStageCategory
  position   Int
  isTerminal Boolean               @default(false) @map("is_terminal")
  status     PipelineStageStatus   @default(ACTIVE)
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")
  deletedAt  DateTime?             @map("deleted_at")

  company      Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  pipeline     HiringPipeline         @relation(fields: [companyId, pipelineId], references: [companyId, id], onDelete: Cascade)
  applications CandidateApplication[]

  @@unique([companyId, id])
  @@unique([companyId, pipelineId, slug])
  @@unique([companyId, pipelineId, position])
  @@index([companyId, pipelineId, status])
  @@map("pipeline_stages")
}

model Job {
  id               String         @id @default(cuid())
  companyId        String         @map("company_id")
  departmentId     String?        @map("department_id")
  teamId           String?        @map("team_id")
  locationId       String?        @map("location_id")
  pipelineId       String         @map("pipeline_id")
  title            String
  slug             String
  descriptionJson  Json           @map("description_json")
  requirementsJson Json           @map("requirements_json")
  employmentType   EmploymentType @map("employment_type")
  workplaceType    WorkplaceType  @map("workplace_type")
  seniorityLevel   SeniorityLevel @map("seniority_level")
  status           JobStatus      @default(DRAFT)
  openedAt         DateTime?      @map("opened_at")
  closedAt         DateTime?      @map("closed_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  company      Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  department   Department?            @relation(fields: [companyId, departmentId], references: [companyId, id], onDelete: Restrict)
  team         Team?                  @relation(fields: [companyId, teamId], references: [companyId, id], onDelete: Restrict)
  location     Location?              @relation(fields: [companyId, locationId], references: [companyId, id], onDelete: Restrict)
  pipeline     HiringPipeline         @relation(fields: [companyId, pipelineId], references: [companyId, id], onDelete: Restrict)
  plans        InterviewPlan[]
  applications CandidateApplication[]
  invitations  CandidateInvitation[]

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, status])
  @@index([companyId, pipelineId])
  @@index([companyId, departmentId])
  @@index([companyId, teamId])
  @@index([companyId, locationId])
  @@map("jobs")
}

model JobTemplate {
  id               String            @id @default(cuid())
  companyId        String            @map("company_id")
  pipelineId       String?           @map("pipeline_id")
  title            String
  slug             String
  descriptionJson  Json              @map("description_json")
  requirementsJson Json              @map("requirements_json")
  employmentType   EmploymentType?   @map("employment_type")
  workplaceType    WorkplaceType?    @map("workplace_type")
  seniorityLevel   SeniorityLevel?   @map("seniority_level")
  status           JobTemplateStatus @default(ACTIVE)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  pipeline HiringPipeline? @relation(fields: [companyId, pipelineId], references: [companyId, id], onDelete: Restrict)
  plans    InterviewPlan[]

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, status])
  @@index([companyId, pipelineId])
  @@map("job_templates")
}

model InterviewPlan {
  id              String              @id @default(cuid())
  companyId       String              @map("company_id")
  jobId           String?             @map("job_id")
  jobTemplateId   String?             @map("job_template_id")
  name            String
  status          InterviewPlanStatus @default(DRAFT)
  activeVersionId String?             @map("active_version_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  job         Job?                   @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Cascade)
  jobTemplate JobTemplate?           @relation(fields: [companyId, jobTemplateId], references: [companyId, id], onDelete: Cascade)
  versions    InterviewPlanVersion[]

  @@unique([companyId, id])
  @@index([companyId, jobId])
  @@index([companyId, jobTemplateId])
  @@index([companyId, status])
  @@map("interview_plans")
}

model InterviewPlanVersion {
  id                    String                     @id @default(cuid())
  companyId             String                     @map("company_id")
  interviewPlanId       String                     @map("interview_plan_id")
  versionNumber         Int                        @map("version_number")
  status                InterviewPlanVersionStatus @default(DRAFT)
  competencyJson        Json                       @map("competency_json")
  questionBlueprintJson Json                       @map("question_blueprint_json")
  durationMinutes       Int                        @map("duration_minutes")
  publishedAt           DateTime?                  @map("published_at")
  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt @map("updated_at")

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  interviewPlan     InterviewPlan      @relation(fields: [companyId, interviewPlanId], references: [companyId, id], onDelete: Cascade)
  interviewSessions InterviewSession[]

  @@unique([companyId, id])
  @@unique([companyId, interviewPlanId, versionNumber])
  @@index([companyId, interviewPlanId, status])
  @@map("interview_plan_versions")
}

model Candidate {
  id              String              @id @default(cuid())
  companyId       String              @map("company_id")
  primaryEmail    String?             @map("primary_email")
  normalizedEmail String?             @map("normalized_email")
  fullName        String              @map("full_name")
  phone           String?
  sourceType      CandidateSourceType @default(MANUAL) @map("source_type")
  sourceLabel     String?             @map("source_label")
  status          CandidateStatus     @default(ACTIVE)
  profileJson     Json                @map("profile_json")
  mergedIntoId    String?             @map("merged_into_id")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  company           Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  mergedInto        Candidate?               @relation("CandidateMergeTarget", fields: [companyId, mergedIntoId], references: [companyId, id], onDelete: Restrict)
  mergedCandidates  Candidate[]              @relation("CandidateMergeTarget")
  applications      CandidateApplication[]
  documents         CandidateDocument[]
  tagAssignments    CandidateTagAssignment[]
  notes             CandidateNote[]
  invitations       CandidateInvitation[]
  interviewSessions InterviewSession[]
  sourceMergeEvents CandidateMergeEvent[]    @relation("CandidateMergeSource")
  targetMergeEvents CandidateMergeEvent[]    @relation("CandidateMergeTargetEvent")
  privacyRequests   PrivacyRequest[]

  @@unique([companyId, id])
  @@unique([companyId, normalizedEmail])
  @@index([companyId, status])
  @@index([companyId, fullName])
  @@map("candidates")
}

model CandidateApplication {
  id             String            @id @default(cuid())
  companyId      String            @map("company_id")
  candidateId    String            @map("candidate_id")
  jobId          String            @map("job_id")
  currentStageId String?           @map("current_stage_id")
  status         ApplicationStatus @default(NEW)
  appliedAt      DateTime          @default(now()) @map("applied_at")
  rejectedAt     DateTime?         @map("rejected_at")
  hiredAt        DateTime?         @map("hired_at")
  metadataJson   Json              @map("metadata_json")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  company           Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  candidate         Candidate             @relation(fields: [companyId, candidateId], references: [companyId, id], onDelete: Cascade)
  job               Job                   @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Restrict)
  currentStage      PipelineStage?        @relation(fields: [companyId, currentStageId], references: [companyId, id], onDelete: Restrict)
  invitations       CandidateInvitation[]
  interviewSessions InterviewSession[]

  @@unique([companyId, id])
  @@unique([companyId, candidateId, jobId])
  @@index([companyId, jobId, status])
  @@index([companyId, candidateId])
  @@index([companyId, currentStageId])
  @@map("candidate_applications")
}

model CandidateDocument {
  id             String                  @id @default(cuid())
  companyId      String                  @map("company_id")
  candidateId    String                  @map("candidate_id")
  type           CandidateDocumentType
  status         CandidateDocumentStatus @default(ACTIVE)
  fileName       String                  @map("file_name")
  contentType    String                  @map("content_type")
  storageKey     String                  @map("storage_key")
  sizeBytes      Int                     @map("size_bytes")
  checksumSha256 String                  @map("checksum_sha256")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  deletedAt      DateTime?               @map("deleted_at")

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  candidate Candidate @relation(fields: [companyId, candidateId], references: [companyId, id], onDelete: Cascade)

  @@unique([companyId, id])
  @@unique([companyId, storageKey])
  @@index([companyId, candidateId, status])
  @@map("candidate_documents")
}

model CandidateTag {
  id        String             @id @default(cuid())
  companyId String             @map("company_id")
  name      String
  slug      String
  color     String?
  status    CandidateTagStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  deletedAt DateTime?          @map("deleted_at")

  company     Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  assignments CandidateTagAssignment[]

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, status])
  @@map("candidate_tags")
}

model CandidateTagAssignment {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  candidateId String   @map("candidate_id")
  tagId       String   @map("tag_id")
  createdAt   DateTime @default(now()) @map("created_at")

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  candidate Candidate    @relation(fields: [companyId, candidateId], references: [companyId, id], onDelete: Cascade)
  tag       CandidateTag @relation(fields: [companyId, tagId], references: [companyId, id], onDelete: Cascade)

  @@unique([companyId, id])
  @@unique([companyId, candidateId, tagId])
  @@index([companyId, tagId])
  @@map("candidate_tag_assignments")
}

model CandidateNote {
  id           String                  @id @default(cuid())
  companyId    String                  @map("company_id")
  candidateId  String                  @map("candidate_id")
  authorUserId String                  @map("author_user_id")
  body         String
  visibility   CandidateNoteVisibility @default(INTERNAL)
  status       CandidateNoteStatus     @default(ACTIVE)
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  deletedAt    DateTime?               @map("deleted_at")

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  candidate Candidate @relation(fields: [companyId, candidateId], references: [companyId, id], onDelete: Cascade)
  author    User      @relation(fields: [companyId, authorUserId], references: [companyId, id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, candidateId, status])
  @@index([companyId, authorUserId])
  @@map("candidate_notes")
}

model CandidateMergeEvent {
  id                String   @id @default(cuid())
  companyId         String   @map("company_id")
  sourceCandidateId String   @map("source_candidate_id")
  targetCandidateId String   @map("target_candidate_id")
  mergedByUserId    String   @map("merged_by_user_id")
  reason            String
  metadataJson      Json     @map("metadata_json")
  createdAt         DateTime @default(now()) @map("created_at")

  company         Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sourceCandidate Candidate @relation("CandidateMergeSource", fields: [companyId, sourceCandidateId], references: [companyId, id], onDelete: Restrict)
  targetCandidate Candidate @relation("CandidateMergeTargetEvent", fields: [companyId, targetCandidateId], references: [companyId, id], onDelete: Restrict)
  mergedByUser    User      @relation(fields: [companyId, mergedByUserId], references: [companyId, id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, sourceCandidateId])
  @@index([companyId, targetCandidateId])
  @@map("candidate_merge_events")
}

model CandidateInvitation {
  id            String           @id @default(cuid())
  companyId     String           @map("company_id")
  candidateId   String           @map("candidate_id")
  applicationId String?          @map("application_id")
  jobId         String           @map("job_id")
  tokenHash     String           @unique @map("token_hash")
  email         String
  status        InvitationStatus @default(DRAFT)
  expiresAt     DateTime         @map("expires_at")
  sentAt        DateTime?        @map("sent_at")
  openedAt      DateTime?        @map("opened_at")
  acceptedAt    DateTime?        @map("accepted_at")
  cancelledAt   DateTime?        @map("cancelled_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  company     Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  candidate   Candidate             @relation(fields: [companyId, candidateId], references: [companyId, id], onDelete: Cascade)
  application CandidateApplication? @relation(fields: [companyId, applicationId], references: [companyId, id], onDelete: Cascade)
  job         Job                   @relation(fields: [companyId, jobId], references: [companyId, id], onDelete: Restrict)
  sessions    InterviewSession[]

  @@unique([companyId, id])
  @@index([companyId, candidateId])
  @@index([companyId, applicationId])
  @@index([companyId, status])
  @@index([expiresAt])
  @@map("candidate_invitations")
}

model InterviewSession {
  id                     String                 @id @default(cuid())
  companyId              String                 @map("company_id")
  candidateId            String                 @map("candidate_id")
  invitationId           String                 @map("invitation_id")
  applicationId          String?                @map("application_id")
  interviewPlanVersionId String?                @map("interview_plan_version_id")
  status                 InterviewSessionStatus @default(NOT_STARTED)
  startedAt              DateTime?              @map("started_at")
  completedAt            DateTime?              @map("completed_at")
  expiresAt              DateTime               @map("expires_at")
  metadataJson           Json                   @map("metadata_json")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")

  company              Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  candidate            Candidate             @relation(fields: [companyId, candidateId], references: [companyId, id], onDelete: Cascade)
  invitation           CandidateInvitation   @relation(fields: [companyId, invitationId], references: [companyId, id], onDelete: Cascade)
  application          CandidateApplication? @relation(fields: [companyId, applicationId], references: [companyId, id], onDelete: Cascade)
  interviewPlanVersion InterviewPlanVersion? @relation(fields: [companyId, interviewPlanVersionId], references: [companyId, id], onDelete: Restrict)

  @@unique([companyId, id])
  @@unique([companyId, invitationId])
  @@index([companyId, candidateId])
  @@index([companyId, applicationId])
  @@index([companyId, status])
  @@index([expiresAt])
  @@map("interview_sessions")
}

model ScheduleEvent {
  id                 String              @id @default(cuid())
  companyId          String              @map("company_id")
  type               ScheduleEventType
  status             ScheduleEventStatus @default(SCHEDULED)
  title              String
  description        String?
  startsAt           DateTime            @map("starts_at")
  endsAt             DateTime            @map("ends_at")
  timeZone           String              @map("time_zone")
  provider           CalendarProvider    @default(INTERNAL)
  providerEventRef   String?             @map("provider_event_ref")
  targetResourceType String?             @map("target_resource_type")
  targetResourceId   String?             @map("target_resource_id")
  metadataJson       Json                @map("metadata_json")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  cancelledAt        DateTime?           @map("cancelled_at")

  company      Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  participants ScheduleParticipant[]

  @@unique([companyId, id])
  @@index([companyId, status, startsAt])
  @@index([companyId, targetResourceType, targetResourceId])
  @@map("schedule_events")
}

model ScheduleParticipant {
  id              String                  @id @default(cuid())
  companyId       String                  @map("company_id")
  scheduleEventId String                  @map("schedule_event_id")
  type            ScheduleParticipantType
  displayName     String                  @map("display_name")
  email           String?
  userId          String?                 @map("user_id")
  candidateId     String?                 @map("candidate_id")
  responseStatus  ScheduleResponseStatus  @default(NEEDS_ACTION) @map("response_status")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  scheduleEvent ScheduleEvent @relation(fields: [companyId, scheduleEventId], references: [companyId, id], onDelete: Cascade)

  @@unique([companyId, id])
  @@index([companyId, scheduleEventId])
  @@index([companyId, userId])
  @@index([companyId, candidateId])
  @@map("schedule_participants")
}

model NotificationIntent {
  id                 String                   @id @default(cuid())
  companyId          String                   @map("company_id")
  type               NotificationIntentType
  channel            NotificationChannel
  status             NotificationIntentStatus @default(PENDING)
  recipientEmail     String                   @map("recipient_email")
  recipientName      String?                  @map("recipient_name")
  targetResourceType String                   @map("target_resource_type")
  targetResourceId   String                   @map("target_resource_id")
  payloadJson        Json                     @map("payload_json")
  scheduledFor       DateTime?                @map("scheduled_for")
  dispatchedAt       DateTime?                @map("dispatched_at")
  cancelledAt        DateTime?                @map("cancelled_at")
  failureReason      String?                  @map("failure_reason")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, status, scheduledFor])
  @@index([companyId, targetResourceType, targetResourceId])
  @@map("notification_intents")
}
