generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  TRIALING
  ARCHIVED

  @@map("company_status")
}

enum PlatformUserStatus {
  ACTIVE
  DISABLED

  @@map("platform_user_status")
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED

  @@map("user_status")
}

enum AuditActorType {
  PLATFORM_USER
  USER
  CANDIDATE_SESSION
  SYSTEM

  @@map("audit_actor_type")
}

enum AuditRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("audit_risk_level")
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED

  @@map("idempotency_status")
}

enum SupportAccessStatus {
  REQUESTED
  ACTIVE
  EXPIRED
  REVOKED
  DENIED

  @@map("support_access_status")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED

  @@map("subscription_status")
}

enum LegalHoldStatus {
  ACTIVE
  RELEASED

  @@map("legal_hold_status")
}

enum PrivacyRequestType {
  ACCESS
  DELETION
  ANONYMIZATION
  EXPORT
  CORRECTION

  @@map("privacy_request_type")
}

enum PrivacyRequestStatus {
  RECEIVED
  VERIFYING
  PROCESSING
  COMPLETED
  DENIED

  @@map("privacy_request_status")
}

enum ExportRequestType {
  CANDIDATE_REPORT
  ROLE_SUMMARY
  AUDIT_EXPORT
  TENANT_EXPORT
  COMPLIANCE_EXPORT

  @@map("export_request_type")
}

enum ExportRequestStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  EXPIRED

  @@map("export_request_status")
}

enum DepartmentStatus {
  ACTIVE
  ARCHIVED

  @@map("department_status")
}

enum TeamStatus {
  ACTIVE
  ARCHIVED

  @@map("team_status")
}

enum TeamMemberRole {
  LEAD
  MEMBER

  @@map("team_member_role")
}

enum LocationStatus {
  ACTIVE
  ARCHIVED

  @@map("location_status")
}

enum LocationMode {
  ONSITE
  HYBRID
  REMOTE

  @@map("location_mode")
}

model Company {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  status        CompanyStatus @default(TRIALING)
  primaryDomain String?       @map("primary_domain")
  logoUrl       String?       @map("logo_url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  users           User[]
  roles           Role[]
  auditEvents     AuditEvent[]
  idempotencyKeys IdempotencyKey[]
  settings        CompanySettings?
  subscription    Subscription?
  entitlements    Entitlement[]
  usageCounters   UsageCounter[]
  supportAccess   SupportAccessSession[]
  legalHolds      LegalHold[]
  privacyRequests PrivacyRequest[]
  exportRequests  ExportRequest[]
  departments     Department[]
  teams           Team[]
  teamMembers     TeamMember[]
  locations       Location[]

  @@index([status])
  @@map("companies")
}

model PlatformUser {
  id        String             @id @default(cuid())
  email     String             @unique
  name      String
  status    PlatformUserStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  supportAccessSessions         SupportAccessSession[] @relation("SupportAccessPlatformUser")
  approvedSupportAccessSessions SupportAccessSession[] @relation("SupportAccessApprover")

  @@index([status])
  @@map("platform_users")
}

model User {
  id          String     @id @default(cuid())
  companyId   String     @map("company_id")
  email       String
  name        String
  status      UserStatus @default(INVITED)
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  company            Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  roles              UserRole[]
  legalHoldsCreated  LegalHold[]     @relation("LegalHoldCreator")
  legalHoldsReleased LegalHold[]     @relation("LegalHoldReleaser")
  exportRequests     ExportRequest[]
  teamMemberships    TeamMember[]

  @@unique([companyId, id])
  @@unique([companyId, email])
  @@index([companyId, status])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String
  key         String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([companyId, id])
  @@unique([companyId, key])
  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String @map("user_id")
  roleId    String @map("role_id")
  companyId String @map("company_id")

  user User @relation(fields: [companyId, userId], references: [companyId, id], onDelete: Cascade)
  role Role @relation(fields: [companyId, roleId], references: [companyId, id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([companyId])
  @@map("user_roles")
}

model AuditEvent {
  id                     String         @id @default(cuid())
  companyId              String?        @map("company_id")
  actorType              AuditActorType @map("actor_type")
  actorId                String?        @map("actor_id")
  requestId              String?        @map("request_id")
  correlationId          String?        @map("correlation_id")
  sessionId              String?        @map("session_id")
  supportAccessSessionId String?        @map("support_access_session_id")
  action                 String
  resourceType           String         @map("resource_type")
  resourceId             String?        @map("resource_id")
  reason                 String?
  riskLevel              AuditRiskLevel @default(LOW) @map("risk_level")
  beforeJson             Json?          @map("before_json")
  afterJson              Json?          @map("after_json")
  ipAddress              String?        @map("ip_address")
  userAgent              String?        @map("user_agent")
  metadataJson           Json?          @map("metadata_json")
  createdAt              DateTime       @default(now()) @map("created_at")

  company              Company?              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  supportAccessSession SupportAccessSession? @relation(fields: [supportAccessSessionId], references: [id], onDelete: Restrict)

  @@index([companyId, createdAt])
  @@index([actorType, actorId])
  @@index([resourceType, resourceId])
  @@index([requestId])
  @@index([correlationId])
  @@index([supportAccessSessionId])
  @@map("audit_events")
}

model IdempotencyKey {
  id           String            @id @default(cuid())
  companyId    String?           @map("company_id")
  key          String
  scope        String
  requestHash  String            @map("request_hash")
  responseHash String?           @map("response_hash")
  status       IdempotencyStatus @default(PROCESSING)
  expiresAt    DateTime          @map("expires_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([scope, key])
  @@index([companyId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model CompanySettings {
  id                  String   @id @default(cuid())
  companyId           String   @unique @map("company_id")
  brandingJson        Json     @map("branding_json")
  retentionPolicyJson Json     @map("retention_policy_json")
  emailSettingsJson   Json     @map("email_settings_json")
  featureFlagsJson    Json     @map("feature_flags_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@map("company_settings")
}

model Subscription {
  id                     String             @id @default(cuid())
  companyId              String             @unique @map("company_id")
  status                 SubscriptionStatus @default(TRIALING)
  planKey                String             @map("plan_key")
  billingProvider        String?            @map("billing_provider")
  billingCustomerRef     String?            @map("billing_customer_ref")
  billingSubscriptionRef String?            @map("billing_subscription_ref")
  currentPeriodStart     DateTime?          @map("current_period_start")
  currentPeriodEnd       DateTime?          @map("current_period_end")
  usageJson              Json               @map("usage_json")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([status])
  @@map("subscriptions")
}

model Entitlement {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  planKey        String   @map("plan_key")
  featureKey     String   @map("feature_key")
  limitValue     Int?     @map("limit_value")
  enabled        Boolean  @default(false)
  overrideReason String?  @map("override_reason")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@unique([companyId, featureKey])
  @@index([companyId, planKey])
  @@map("entitlements")
}

model UsageCounter {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  periodStart  DateTime @map("period_start")
  periodEnd    DateTime @map("period_end")
  metricKey    String   @map("metric_key")
  count        Int      @default(0)
  metadataJson Json     @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@unique([companyId, periodStart, periodEnd, metricKey])
  @@index([companyId, metricKey])
  @@map("usage_counters")
}

model SupportAccessSession {
  id                       String              @id @default(cuid())
  companyId                String              @map("company_id")
  platformUserId           String              @map("platform_user_id")
  status                   SupportAccessStatus @default(REQUESTED)
  reasonCode               String              @map("reason_code")
  reasonText               String              @map("reason_text")
  approvedByPlatformUserId String?             @map("approved_by_platform_user_id")
  startedAt                DateTime?           @map("started_at")
  expiresAt                DateTime            @map("expires_at")
  endedAt                  DateTime?           @map("ended_at")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  company                Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  platformUser           PlatformUser  @relation("SupportAccessPlatformUser", fields: [platformUserId], references: [id], onDelete: Restrict)
  approvedByPlatformUser PlatformUser? @relation("SupportAccessApprover", fields: [approvedByPlatformUserId], references: [id], onDelete: Restrict)
  auditEvents            AuditEvent[]

  @@unique([companyId, id])
  @@index([companyId, status])
  @@index([platformUserId, status])
  @@index([expiresAt])
  @@map("support_access_sessions")
}

model LegalHold {
  id               String          @id @default(cuid())
  companyId        String          @map("company_id")
  name             String
  description      String?
  status           LegalHoldStatus @default(ACTIVE)
  createdByUserId  String          @map("created_by_user_id")
  releasedByUserId String?         @map("released_by_user_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  releasedAt       DateTime?       @map("released_at")

  company        Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdByUser  User    @relation("LegalHoldCreator", fields: [companyId, createdByUserId], references: [companyId, id], onDelete: Restrict)
  releasedByUser User?   @relation("LegalHoldReleaser", fields: [companyId, releasedByUserId], references: [companyId, id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, status])
  @@map("legal_holds")
}

model PrivacyRequest {
  id             String               @id @default(cuid())
  companyId      String               @map("company_id")
  candidateId    String?              @map("candidate_id")
  type           PrivacyRequestType
  status         PrivacyRequestStatus @default(RECEIVED)
  requesterEmail String               @map("requester_email")
  reason         String?
  completedAt    DateTime?            @map("completed_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, candidateId])
  @@index([companyId, status])
  @@map("privacy_requests")
}

model ExportRequest {
  id                String              @id @default(cuid())
  companyId         String              @map("company_id")
  requestedByUserId String              @map("requested_by_user_id")
  type              ExportRequestType
  status            ExportRequestStatus @default(PENDING)
  resourceType      String?             @map("resource_type")
  resourceId        String?             @map("resource_id")
  storageKey        String?             @map("storage_key")
  expiresAt         DateTime?           @map("expires_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  company         Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  requestedByUser User    @relation(fields: [companyId, requestedByUserId], references: [companyId, id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, status])
  @@index([companyId, requestedByUserId])
  @@map("export_requests")
}

model Department {
  id          String           @id @default(cuid())
  companyId   String           @map("company_id")
  name        String
  slug        String
  description String?
  status      DepartmentStatus @default(ACTIVE)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  teams   Team[]

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, status])
  @@map("departments")
}

model Team {
  id           String     @id @default(cuid())
  companyId    String     @map("company_id")
  departmentId String?    @map("department_id")
  name         String
  slug         String
  description  String?
  status       TeamStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  department Department?  @relation(fields: [companyId, departmentId], references: [companyId, id], onDelete: Restrict)
  members    TeamMember[]

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, departmentId])
  @@index([companyId, status])
  @@map("teams")
}

model TeamMember {
  id        String         @id @default(cuid())
  companyId String         @map("company_id")
  teamId    String         @map("team_id")
  userId    String         @map("user_id")
  role      TeamMemberRole @default(MEMBER)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  team    Team    @relation(fields: [companyId, teamId], references: [companyId, id], onDelete: Cascade)
  user    User    @relation(fields: [companyId, userId], references: [companyId, id], onDelete: Cascade)

  @@unique([companyId, id])
  @@unique([companyId, teamId, userId])
  @@index([companyId, userId])
  @@map("team_members")
}

model Location {
  id          String         @id @default(cuid())
  companyId   String         @map("company_id")
  name        String
  slug        String
  mode        LocationMode
  status      LocationStatus @default(ACTIVE)
  addressJson Json?          @map("address_json")
  timeZone    String?        @map("time_zone")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@unique([companyId, slug])
  @@index([companyId, status])
  @@index([companyId, mode])
  @@map("locations")
}
