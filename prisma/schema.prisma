model HrReport {
  id                  String         @id @default(cuid())
  companyId           String         @map("company_id")
  interviewSessionId  String         @map("interview_session_id")
  transcriptId        String         @map("transcript_id")
  evaluationVersionId String         @map("evaluation_version_id")
  activeVersionId     String?        @map("active_version_id")
  status              HrReportStatus @default(PENDING)
  retentionDeleteAt   DateTime       @map("retention_delete_at")
  legalHoldId         String?        @map("legal_hold_id")
  legalHoldActive     Boolean        @default(false) @map("legal_hold_active")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  interviewSession  InterviewSession  @relation(fields: [companyId, interviewSessionId], references: [companyId, id], onDelete: Cascade)
  transcript        Transcript        @relation(fields: [companyId, transcriptId], references: [companyId, id], onDelete: Restrict)
  evaluationVersion EvaluationVersion @relation(fields: [companyId, evaluationVersionId], references: [companyId, id], onDelete: Restrict)
  activeVersion     HrReportVersion?  @relation("ActiveHrReportVersion", fields: [companyId, activeVersionId], references: [companyId, id], onDelete: Restrict)
  legalHold         LegalHold?        @relation(fields: [companyId, legalHoldId], references: [companyId, id], onDelete: Restrict)
  versions          HrReportVersion[] @relation("HrReportVersions")

  @@unique([companyId, id])
  @@unique([companyId, interviewSessionId])
  @@index([companyId, status, createdAt])
  @@index([companyId, retentionDeleteAt])
  @@map("hr_reports")
}

model HrReportVersion {
  id                  String         @id @default(cuid())
  companyId           String         @map("company_id")
