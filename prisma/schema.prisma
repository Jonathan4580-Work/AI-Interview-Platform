  updatedAt           DateTime       @updatedAt @map("updated_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  hrReport          HrReport          @relation("HrReportVersions", fields: [companyId, hrReportId], references: [companyId, id], onDelete: Cascade)
  activeForReport   HrReport[]        @relation("ActiveHrReportVersion")
  interviewSession  InterviewSession  @relation(fields: [companyId, interviewSessionId], references: [companyId, id], onDelete: Cascade)
  evaluationVersion EvaluationVersion @relation(fields: [companyId, evaluationVersionId], references: [companyId, id], onDelete: Restrict)
  supersededByVersion HrReportVersion? @relation("HrReportSupersession", fields: [companyId, supersededByVersionId], references: [companyId, id], onDelete: Restrict)
  supersededVersions HrReportVersion[] @relation("HrReportSupersession")

  @@unique([companyId, id])
  @@unique([companyId, hrReportId, versionNumber])
  @@index([companyId, interviewSessionId, status])
  @@map("hr_report_versions")
}

model EvaluationOverride {
  id                    String                   @id @default(cuid())
  companyId             String                   @map("company_id")
