model CandidateSession {
  id                 String                 @id @default(cuid())
  companyId          String                 @map("company_id")
  candidateId        String                 @map("candidate_id")
  invitationId       String                 @map("invitation_id")
  interviewSessionId String?                @map("interview_session_id")
  sessionTokenHash   String                 @unique @map("session_token_hash")
  csrfTokenHash      String                 @map("csrf_token_hash")
  activeLockKey      String?                @map("active_lock_key")
  status             CandidateSessionStatus @default(ACTIVE)
  createdFromIpHash  String?                @map("created_from_ip_hash")
  createdFromUserAgent String?              @map("created_from_user_agent")
  lastSeenAt         DateTime               @default(now()) @map("last_seen_at")
  expiresAt          DateTime               @map("expires_at")
  revokedAt          DateTime?              @map("revoked_at")
  completedAt        DateTime?              @map("completed_at")
  metadataJson       Json                   @map("metadata_json")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  company          Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  candidate        Candidate           @relation(fields: [companyId, candidateId], references: [companyId, id], onDelete: Cascade)
  invitation       CandidateInvitation @relation(fields: [companyId, invitationId], references: [companyId, id], onDelete: Cascade)
  interviewSession InterviewSession?   @relation(fields: [companyId, interviewSessionId], references: [companyId, id], onDelete: Restrict)
  continuations    CandidateSessionContinuation[]
  consentRecords   CandidateConsentRecord[]
  readinessChecks  ReadinessCheck[]
  identityVerifications IdentityVerification[]
  webcamSnapshots  WebcamSnapshot[]
  accommodationRequests AccommodationRequest[]
  supportRequests  CandidateSupportRequest[]
  withdrawals      CandidateWithdrawal[]
  interviewActivityEvents InterviewActivityEvent[]
  interviewRecoveryCheckpoints InterviewRecoveryCheckpoint[]

  @@unique([companyId, id])
  @@unique([companyId, activeLockKey])
  @@index([companyId, invitationId, status])
  @@index([companyId, candidateId])
  @@index([expiresAt])
  @@map("candidate_sessions")
}

model CandidateSessionContinuation {
  id                String   @id @default(cuid())
  companyId         String   @map("company_id")
  candidateSessionId String  @map("candidate_session_id")
  resumeTokenHash   String   @unique @map("resume_token_hash")
  consumedAt        DateTime? @map("consumed_at")
  expiresAt         DateTime @map("expires_at")
  createdAt         DateTime @default(now()) @map("created_at")

  company          Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  candidateSession CandidateSession @relation(fields: [companyId, candidateSessionId], references: [companyId, id], onDelete: Cascade)

  @@unique([companyId, id])
  @@index([companyId, candidateSessionId])
  @@index([expiresAt])
  @@map("candidate_session_continuations")
}

model CandidateTokenAttempt {
