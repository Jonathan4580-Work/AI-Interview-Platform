model Company {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  status        CompanyStatus @default(TRIALING)
  primaryDomain String?       @map("primary_domain")
  logoUrl       String?       @map("logo_url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  users                   User[]
  roles                   Role[]
  auditEvents             AuditEvent[]
  idempotencyKeys         IdempotencyKey[]
  settings                CompanySettings?
  subscription            Subscription?
  entitlements            Entitlement[]
  usageCounters           UsageCounter[]
  supportAccess           SupportAccessSession[]
  authCredentials         AuthCredential[]
  authSessions            AuthSession[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  mfaFactors              MfaFactor[]
  legalHolds              LegalHold[]
  privacyRequests         PrivacyRequest[]
  exportRequests          ExportRequest[]
  departments             Department[]
  teams                   Team[]
  teamMembers             TeamMember[]
  locations               Location[]
  hiringPipelines         HiringPipeline[]
  pipelineStages          PipelineStage[]
  jobs                    Job[]
  jobTemplates            JobTemplate[]
  interviewPlans          InterviewPlan[]
  interviewPlanVersions   InterviewPlanVersion[]
  candidates              Candidate[]
  candidateApplications   CandidateApplication[]
  candidateDocuments      CandidateDocument[]
  candidateTags           CandidateTag[]
  candidateTagAssignments CandidateTagAssignment[]
  candidateNotes          CandidateNote[]
  candidateMergeEvents    CandidateMergeEvent[]
  candidateInvitations    CandidateInvitation[]
  interviewSessions       InterviewSession[]
  candidateSessions       CandidateSession[]
  candidateSessionContinuations CandidateSessionContinuation[]
  candidateTokenAttempts  CandidateTokenAttempt[]
  candidateConsentRecords CandidateConsentRecord[]
  readinessChecks         ReadinessCheck[]
  identityVerifications   IdentityVerification[]
  webcamSnapshots         WebcamSnapshot[]
  accommodationRequests   AccommodationRequest[]
  candidateSupportRequests CandidateSupportRequest[]
  candidateWithdrawals    CandidateWithdrawal[]
  scheduleEvents          ScheduleEvent[]
  scheduleParticipants    ScheduleParticipant[]
  notificationIntents     NotificationIntent[]
  emailSettings           EmailSettings?
  smtpProfiles            SmtpProfile[]
  verifiedSenderDomains   VerifiedSenderDomain[]
  emailTemplates          EmailTemplate[]
  emailDeliveries         EmailDelivery[]
  emailDeliveryAttempts   EmailDeliveryAttempt[]
  emailEvents             EmailEvent[]

  @@index([status])
  @@map("companies")
}

model PlatformUser {
  id        String             @id @default(cuid())
  email     String             @unique
  name      String
  status    PlatformUserStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  supportAccessSessions         SupportAccessSession[]   @relation("SupportAccessPlatformUser")
  approvedSupportAccessSessions SupportAccessSession[]   @relation("SupportAccessApprover")
  credentials                   AuthCredential[]
  sessions                      AuthSession[]
  passwordResetTokens           PasswordResetToken[]
  emailVerificationTokens       EmailVerificationToken[]
  mfaFactors                    MfaFactor[]

  @@index([status])
  @@map("platform_users")
}

model User {
  id          String     @id @default(cuid())
  companyId   String     @map("company_id")
  email       String
  name        String
  status      UserStatus @default(INVITED)
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  roles                   UserRole[]
  legalHoldsCreated       LegalHold[]              @relation("LegalHoldCreator")
  legalHoldsReleased      LegalHold[]              @relation("LegalHoldReleaser")
  exportRequests          ExportRequest[]
  teamMemberships         TeamMember[]
  candidateNotes          CandidateNote[]
  candidateMergeEvents    CandidateMergeEvent[]
  credentials             AuthCredential[]
  sessions                AuthSession[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  mfaFactors              MfaFactor[]

  @@unique([companyId, id])
  @@unique([companyId, email])
  @@index([companyId, status])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  name        String
  key         String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([companyId, id])
  @@unique([companyId, key])
  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String @map("user_id")
  roleId    String @map("role_id")
  companyId String @map("company_id")

  user User @relation(fields: [companyId, userId], references: [companyId, id], onDelete: Cascade)
  role Role @relation(fields: [companyId, roleId], references: [companyId, id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([companyId])
  @@map("user_roles")
}

model AuthCredential {
  id                String          @id @default(cuid())
  subjectType       AuthSubjectType @map("subject_type")
  companyId         String?         @map("company_id")
  userId            String?         @map("user_id")
  platformUserId    String?         @map("platform_user_id")
  passwordHash      String          @map("password_hash")
  emailVerifiedAt   DateTime?       @map("email_verified_at")
  passwordUpdatedAt DateTime        @default(now()) @map("password_updated_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  company      Company?      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user         User?         @relation(fields: [companyId, userId], references: [companyId, id], onDelete: Cascade)
  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@unique([platformUserId])
  @@index([companyId])
  @@map("auth_credentials")
}

model AuthSession {
  id               String            @id @default(cuid())
  subjectType      AuthSubjectType   @map("subject_type")
  companyId        String?           @map("company_id")
  userId           String?           @map("user_id")
  platformUserId   String?           @map("platform_user_id")
  sessionTokenHash String            @unique @map("session_token_hash")
  refreshTokenHash String            @unique @map("refresh_token_hash")
  csrfTokenHash    String            @map("csrf_token_hash")
  status           AuthSessionStatus @default(ACTIVE)
  ipAddress        String?           @map("ip_address")
  userAgent        String?           @map("user_agent")
  lastSeenAt       DateTime          @default(now()) @map("last_seen_at")
  expiresAt        DateTime          @map("expires_at")
  refreshExpiresAt DateTime          @map("refresh_expires_at")
  revokedAt        DateTime?         @map("revoked_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  company      Company?      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user         User?         @relation(fields: [companyId, userId], references: [companyId, id], onDelete: Cascade)
  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@unique([companyId, id])
  @@index([companyId, userId, status])
  @@index([platformUserId, status])
  @@index([expiresAt])
  @@index([refreshExpiresAt])
  @@map("auth_sessions")
}

model PasswordResetToken {
  id             String          @id @default(cuid())
  subjectType    AuthSubjectType @map("subject_type")
  companyId      String?         @map("company_id")
  userId         String?         @map("user_id")
  platformUserId String?         @map("platform_user_id")
  tokenHash      String          @unique @map("token_hash")
  expiresAt      DateTime        @map("expires_at")
  usedAt         DateTime?       @map("used_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  company      Company?      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user         User?         @relation(fields: [companyId, userId], references: [companyId, id], onDelete: Cascade)
  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([companyId, userId])
  @@index([platformUserId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id             String          @id @default(cuid())
  subjectType    AuthSubjectType @map("subject_type")
  companyId      String?         @map("company_id")
  userId         String?         @map("user_id")
  platformUserId String?         @map("platform_user_id")
  tokenHash      String          @unique @map("token_hash")
  expiresAt      DateTime        @map("expires_at")
  verifiedAt     DateTime?       @map("verified_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  company      Company?      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user         User?         @relation(fields: [companyId, userId], references: [companyId, id], onDelete: Cascade)
  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([companyId, userId])
  @@index([platformUserId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model MfaFactor {
  id             String          @id @default(cuid())
  subjectType    AuthSubjectType @map("subject_type")
  companyId      String?         @map("company_id")
  userId         String?         @map("user_id")
  platformUserId String?         @map("platform_user_id")
  type           MfaFactorType
  status         MfaFactorStatus @default(PENDING)
  secretRef      String?         @map("secret_ref")
  metadataJson   Json            @map("metadata_json")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  disabledAt     DateTime?       @map("disabled_at")

  company      Company?      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user         User?         @relation(fields: [companyId, userId], references: [companyId, id], onDelete: Cascade)
  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, type])
  @@unique([platformUserId, type])
  @@index([companyId, status])
  @@map("mfa_factors")
}

model AuditEvent {
  id                     String         @id @default(cuid())
  companyId              String?        @map("company_id")
  actorType              AuditActorType @map("actor_type")
  actorId                String?        @map("actor_id")
  requestId              String?        @map("request_id")
  correlationId          String?        @map("correlation_id")
  sessionId              String?        @map("session_id")
  supportAccessSessionId String?        @map("support_access_session_id")
  action                 String
  resourceType           String         @map("resource_type")
  resourceId             String?        @map("resource_id")
  reason                 String?
  riskLevel              AuditRiskLevel @default(LOW) @map("risk_level")
  beforeJson             Json?          @map("before_json")
  afterJson              Json?          @map("after_json")
  ipAddress              String?        @map("ip_address")
  userAgent              String?        @map("user_agent")
  metadataJson           Json?          @map("metadata_json")
  createdAt              DateTime       @default(now()) @map("created_at")

  company              Company?              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  supportAccessSession SupportAccessSession? @relation(fields: [supportAccessSessionId], references: [id], onDelete: Restrict)

  @@index([companyId, createdAt])
  @@index([actorType, actorId])
  @@index([resourceType, resourceId])
  @@index([requestId])
  @@index([correlationId])
  @@index([supportAccessSessionId])
  @@map("audit_events")
}

model IdempotencyKey {
  id           String            @id @default(cuid())
  companyId    String?           @map("company_id")
  key          String
  scope        String
  requestHash  String            @map("request_hash")
  responseHash String?           @map("response_hash")
  status       IdempotencyStatus @default(PROCESSING)
  expiresAt    DateTime          @map("expires_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  company Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([scope, key])
  @@index([companyId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model CompanySettings {
  id                  String   @id @default(cuid())
  companyId           String   @unique @map("company_id")
  brandingJson        Json     @map("branding_json")
  retentionPolicyJson Json     @map("retention_policy_json")
  emailSettingsJson   Json     @map("email_settings_json")
  featureFlagsJson    Json     @map("feature_flags_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@map("company_settings")
}

model Subscription {
  id                     String             @id @default(cuid())
  companyId              String             @unique @map("company_id")
  status                 SubscriptionStatus @default(TRIALING)
  planKey                String             @map("plan_key")
  billingProvider        String?            @map("billing_provider")
  billingCustomerRef     String?            @map("billing_customer_ref")
  billingSubscriptionRef String?            @map("billing_subscription_ref")
  currentPeriodStart     DateTime?          @map("current_period_start")
  currentPeriodEnd       DateTime?          @map("current_period_end")
  usageJson              Json               @map("usage_json")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([status])
  @@map("subscriptions")
}

model Entitlement {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  planKey        String   @map("plan_key")
  featureKey     String   @map("feature_key")
  limitValue     Int?     @map("limit_value")
  enabled        Boolean  @default(false)
  overrideReason String?  @map("override_reason")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, id])
