model AiRubricTemplate {
  id          String           @id @default(cuid())
  companyId   String?          @map("company_id")
  key         String
  name        String
  status      AiArtifactStatus @default(DRAFT)
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  archivedAt  DateTime?        @map("archived_at")

  company  Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  versions AiRubricVersion[]

  @@unique([companyId, id])
  @@unique([companyId, key])
  @@index([companyId, status])
  @@map("ai_rubric_templates")
}

model AiRubricVersion {
  id                   String           @id @default(cuid())
  companyId            String?          @map("company_id")
  rubricTemplateId     String           @map("rubric_template_id")
  versionNumber        Int              @map("version_number")
  status               AiArtifactStatus @default(DRAFT)
  rubricHash           String           @map("rubric_hash")
  scoreMin             Int              @default(1) @map("score_min")
  scoreMax             Int              @default(5) @map("score_max")
  competencySchemaJson Json             @map("competency_schema_json")
  publishedAt          DateTime?        @map("published_at")
  archivedAt           DateTime?        @map("archived_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  company        Company?         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  rubricTemplate AiRubricTemplate @relation(fields: [rubricTemplateId], references: [id], onDelete: Restrict)
  evaluationRuns EvaluationRun[]
  evaluationVersions EvaluationVersion[]

  @@unique([companyId, id])
  @@unique([rubricTemplateId, versionNumber])
  @@index([companyId, status])
  @@map("ai_rubric_versions")
}

model EvaluationRun {
  id                     String                @id @default(cuid())
  companyId              String                @map("company_id")
  interviewSessionId     String                @map("interview_session_id")
  transcriptId           String                @map("transcript_id")
  transcriptVersionId    String                @map("transcript_version_id")
  promptVersionId        String                @map("prompt_version_id")
  rubricVersionId        String                @map("rubric_version_id")
  provider               EvaluationProviderKey
  providerModel          String                @map("provider_model")
  providerModelVersion   String?               @map("provider_model_version")
  status                 EvaluationStatus      @default(PENDING)
  redactionPolicyVersion String                 @map("redaction_policy_version")
  outputNormalizationVersion String            @map("output_normalization_version")
  requestStartedAt       DateTime?             @map("request_started_at")
  responseReceivedAt     DateTime?             @map("response_received_at")
  latencyMs              Int?                  @map("latency_ms")
  usageJson              Json                  @map("usage_json")
  estimatedCostCents     Int?                  @map("estimated_cost_cents")
  failureKind            WorkflowFailureKind?  @map("failure_kind")
  failureCode            String?               @map("failure_code")
  failureMessage         String?               @map("failure_message")
  metadataJson           Json                  @map("metadata_json")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  interviewSession  InterviewSession  @relation(fields: [companyId, interviewSessionId], references: [companyId, id], onDelete: Cascade)
  transcript        Transcript        @relation(fields: [companyId, transcriptId], references: [companyId, id], onDelete: Restrict)
  transcriptVersion TranscriptVersion @relation(fields: [companyId, transcriptVersionId], references: [companyId, id], onDelete: Restrict)
  promptVersion     AiPromptVersion   @relation(fields: [promptVersionId], references: [id], onDelete: Restrict)
  rubricVersion     AiRubricVersion   @relation(fields: [rubricVersionId], references: [id], onDelete: Restrict)
  versions          EvaluationVersion[]
  providerPayloads  EvaluationProviderPayload[]

  @@unique([companyId, id])
  @@index([companyId, interviewSessionId, status])
  @@index([companyId, status, createdAt])
  @@map("evaluation_runs")
}

model EvaluationVersion {
  id                     String                 @id @default(cuid())
  companyId              String                 @map("company_id")
  evaluationRunId        String                 @map("evaluation_run_id")
  interviewSessionId     String                 @map("interview_session_id")
  transcriptId           String                 @map("transcript_id")
  transcriptVersionId    String                 @map("transcript_version_id")
  promptVersionId        String                 @map("prompt_version_id")
  rubricVersionId        String                 @map("rubric_version_id")
  versionNumber          Int                    @map("version_number")
  status                 EvaluationStatus       @default(PROCESSING)
  reviewStatus           EvaluationReviewStatus @default(UNREVIEWED) @map("review_status")
  overallScore           Float?                 @map("overall_score")
  scoreMin               Int                    @map("score_min")
  scoreMax               Int                    @map("score_max")
  overallConfidence      ConfidenceLevel        @default(MODERATE) @map("overall_confidence")
  transcriptConfidence   ConfidenceLevel        @default(MODERATE) @map("transcript_confidence")
  summary                String
  recommendation         String?
  decisionSupportDisclaimer String              @map("decision_support_disclaimer")
  supersededByVersionId  String?                @map("superseded_by_version_id")
  reviewedAt             DateTime?              @map("reviewed_at")
  reviewedByUserId       String?                @map("reviewed_by_user_id")
  reviewReason           String?                @map("review_reason")
  completedAt            DateTime?              @map("completed_at")
  failureCode            String?                @map("failure_code")
  failureMessage         String?                @map("failure_message")
  metadataJson           Json                   @map("metadata_json")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")

  company          Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  evaluationRun    EvaluationRun    @relation(fields: [companyId, evaluationRunId], references: [companyId, id], onDelete: Cascade)
  interviewSession InterviewSession @relation(fields: [companyId, interviewSessionId], references: [companyId, id], onDelete: Cascade)
  transcript       Transcript       @relation(fields: [companyId, transcriptId], references: [companyId, id], onDelete: Restrict)
  transcriptVersion TranscriptVersion @relation(fields: [companyId, transcriptVersionId], references: [companyId, id], onDelete: Restrict)
  promptVersion    AiPromptVersion  @relation(fields: [promptVersionId], references: [id], onDelete: Restrict)
  rubricVersion    AiRubricVersion  @relation(fields: [rubricVersionId], references: [id], onDelete: Restrict)
  scores           EvaluationCompetencyScore[]
  evidenceCitations EvaluationEvidenceCitation[]
  observations     EvaluationObservation[]
  limitations      EvaluationLimitation[]
  reports          HrReport[]
  reportVersions   HrReportVersion[]
  overrides        EvaluationOverride[]
  supersededByVersion EvaluationVersion? @relation("EvaluationSupersession", fields: [companyId, supersededByVersionId], references: [companyId, id], onDelete: Restrict)
  supersededVersions EvaluationVersion[] @relation("EvaluationSupersession")

  @@unique([companyId, id])
  @@unique([companyId, evaluationRunId, versionNumber])
  @@index([companyId, interviewSessionId, status])
  @@index([companyId, reviewStatus, createdAt])
  @@map("evaluation_versions")
}

model EvaluationCompetencyScore {
  id                  String          @id @default(cuid())
  companyId           String          @map("company_id")
  evaluationVersionId String          @map("evaluation_version_id")
  interviewSessionId  String          @map("interview_session_id")
  competencyKey       String          @map("competency_key")
  label               String
  score               Float?
  maxScore            Int             @map("max_score")
  confidence          ConfidenceLevel
  rationale           String
  incomplete          Boolean         @default(false)
  createdAt           DateTime        @default(now()) @map("created_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  evaluationVersion EvaluationVersion @relation(fields: [companyId, evaluationVersionId], references: [companyId, id], onDelete: Cascade)
  interviewSession  InterviewSession  @relation(fields: [companyId, interviewSessionId], references: [companyId, id], onDelete: Cascade)
  evidenceCitations EvaluationEvidenceCitation[]
  overrides         EvaluationOverride[]

  @@unique([companyId, id])
  @@unique([companyId, evaluationVersionId, competencyKey])
  @@index([companyId, interviewSessionId, competencyKey])
  @@map("evaluation_competency_scores")
}

model EvaluationEvidenceCitation {
  id                    String   @id @default(cuid())
  companyId             String   @map("company_id")
  evaluationVersionId   String   @map("evaluation_version_id")
  competencyScoreId     String?  @map("competency_score_id")
  interviewSessionId    String   @map("interview_session_id")
  transcriptSegmentId   String?  @map("transcript_segment_id")
  interviewTurnId       String?  @map("interview_turn_id")
  competencyKey         String   @map("competency_key")
  claim                 String
  excerpt               String
  startMs               Int?     @map("start_ms")
  endMs                 Int?     @map("end_ms")
  createdAt             DateTime @default(now()) @map("created_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  evaluationVersion EvaluationVersion @relation(fields: [companyId, evaluationVersionId], references: [companyId, id], onDelete: Cascade)
  competencyScore   EvaluationCompetencyScore? @relation(fields: [companyId, competencyScoreId], references: [companyId, id], onDelete: Cascade)
  interviewSession  InterviewSession  @relation(fields: [companyId, interviewSessionId], references: [companyId, id], onDelete: Cascade)
  transcriptSegment TranscriptSegment? @relation(fields: [companyId, transcriptSegmentId], references: [companyId, id], onDelete: Restrict)
  interviewTurn     InterviewTurn?    @relation(fields: [companyId, interviewTurnId], references: [companyId, id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, evaluationVersionId, competencyKey])
  @@index([companyId, transcriptSegmentId])
  @@index([companyId, interviewTurnId])
  @@map("evaluation_evidence_citations")
}

model EvaluationObservation {
  id                  String   @id @default(cuid())
