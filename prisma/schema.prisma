  ACTIVE
  SUSPENDED
  TRIALING
  ARCHIVED

  @@map("company_status")
}

enum PlatformUserStatus {
  ACTIVE
  DISABLED

  @@map("platform_user_status")
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED

  @@map("user_status")
}

