  createdByUserId       String                   @map("created_by_user_id")
  createdAt             DateTime                 @default(now()) @map("created_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  interviewSession  InterviewSession  @relation(fields: [companyId, interviewSessionId], references: [companyId, id], onDelete: Cascade)
  evaluationVersion EvaluationVersion @relation(fields: [companyId, evaluationVersionId], references: [companyId, id], onDelete: Restrict)
  competencyScore   EvaluationCompetencyScore? @relation(fields: [companyId, competencyScoreId], references: [companyId, id], onDelete: Restrict)
  createdByUser     User              @relation(fields: [companyId, createdByUserId], references: [companyId, id], onDelete: Restrict)

  @@unique([companyId, id])
  @@index([companyId, interviewSessionId, createdAt])
  @@index([companyId, evaluationVersionId])
  @@map("evaluation_overrides")
}

model HumanDecisionHistory {
